# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el archivo .env al repositorio

# Google Cloud Platform
GCP_PROJECT_ID=tu-proyecto-gcp
GCP_PUBSUB_TOPIC=rapiro-events
GCP_FIRESTORE_COLLECTION=detections
GCP_STORAGE_BUCKET=rapiro-captures

# RAPIRO - Puerto serial
# Windows: COM3, COM4, etc.
# Linux/Raspberry Pi: /dev/ttyUSB0 o /dev/ttyACM0
RAPIRO_SERIAL_PORT=COM3
RAPIRO_BAUD_RATE=9600

# Cámara: índice local (0, 1...) o URL HTTP de IP Webcam
CAMERA_SOURCE=0
# CAMERA_SOURCE=http://192.168.1.100:8080/video

# Corrige efecto espejo en preview y capturas (1=activo, 0=desactivado)
CAMERA_FLIP_HORIZONTAL=1

# Rotación de cámara: AUTO (rotar 90° si w > h), 0 o NONE (sin rotación), 90, 180, 270
CAMERA_ROTATION=AUTO

# Umbrales del sistema
CONFIDENCE_THRESHOLD=0.85
UNKNOWN_PERSON_LABEL=desconocido

# Weights & Biases (monitoreo de entrenamiento)
WANDB_PROJECT=rapiro-tpi-2026
